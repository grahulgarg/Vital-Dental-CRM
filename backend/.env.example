# ─────────────────────────────────────────────────────────────────────────────
#  Vital Dental — Environment Variables
#  Copy this file to .env and fill in your values.
#  The .env file is NEVER shared or uploaded — it stays on your PC only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Twilio WhatsApp API ──────────────────────────────────────────────────────
# Sign up at https://www.twilio.com (free sandbox available for testing)
# Find these in your Twilio Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The WhatsApp number to SEND from (Twilio Sandbox: whatsapp:+14155238886)
# For production, this is your approved Twilio WhatsApp Business number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Google Review ────────────────────────────────────────────────────────────
# Get this from your Google Business Profile → Get more reviews → Share link
GOOGLE_REVIEW_URL=https://g.page/r/YOUR_CLINIC_ID/review
